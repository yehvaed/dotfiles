

! SOURCE PROGRAM SPECIFIC FILES !
URxvt*termName:                 rxvt-256color
URxvt*font:                     xft:Consolas:pixelsize=12
URxvt.depth:                    0
URxvt*lineSpace:                1.40
URxvt.letterSpace:              1.65
URxvt.iso14755:                 false
URxvt.iso14755_52:              false
URxvt*geometry:                 140x30
URxvt.scrollBar:                false
URxvt*loginShell:               true
URxvt.internalBorder:           10
URxvt.perl-ext-common:          default,clipboard
URxvt.keysym.Shift-Control-V:   eval:paste_clipboard
URxvt.keysym.Shift-Control-C:   eval:selection_to_clipboard
URxvt.clipboard.autocopy:       true

! Colors
*background:   #080808
*foreground:   #eff0eb
*cursorColor:  #9aedfe

! SOURCE TERMINAL COLORS !
*color0:      #33303b
*color8:      #4f4b58
*color1:      #ff5c57
*color9:      #ff5c57
*color2:      #5af78e
*color10:     #5af78e
*color3:      #f3f99d
*color11:     #f3f99d
*color4:      #57c7ff
*color12:     #57c7ffs
*color5:      #ff6ac1
*color13:     #ff6ac1
*color6:      #9aedfe
*color14:     #9aedfe
*color7:      #eff0eb
*color15:     #eff0ebą
